#!/bin/sh

set -e

WRAPPER_DIR="$(cd "$(dirname "$0")" && pwd)/.mvn/wrapper"
PROPS_FILE="$WRAPPER_DIR/maven-wrapper.properties"

if [ ! -f "$PROPS_FILE" ]; then
  echo "Maven wrapper properties not found: $PROPS_FILE"
  exit 1
fi

DISTRIBUTION_URL="$(grep '^distributionUrl=' "$PROPS_FILE" | sed 's/^distributionUrl=//')"

if [ -z "$DISTRIBUTION_URL" ]; then
  echo "distributionUrl is missing in $PROPS_FILE"
  exit 1
fi

ZIP_NAME="$(basename "$DISTRIBUTION_URL")"
ZIP_PATH="$WRAPPER_DIR/$ZIP_NAME"
EXTRACT_DIR="$WRAPPER_DIR/dist"
MAVEN_BIN="$EXTRACT_DIR/apache-maven-3.9.9/bin/mvn"

mkdir -p "$WRAPPER_DIR" "$EXTRACT_DIR"

if [ ! -x "$MAVEN_BIN" ]; then
  if [ ! -f "$ZIP_PATH" ]; then
    echo "Downloading Maven distribution..."
    curl -fsSL "$DISTRIBUTION_URL" -o "$ZIP_PATH"
  fi

  echo "Extracting Maven distribution..."
  unzip -oq "$ZIP_PATH" -d "$EXTRACT_DIR"
fi

exec "$MAVEN_BIN" "$@"
